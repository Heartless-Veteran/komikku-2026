{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":disableDependencyDashboard"
  ],
  "labels": ["dependencies"],
  "schedule": ["before 6am on monday"],
  "timezone": "Asia/Shanghai",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "gradle": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false
    },
    {
      "matchManagers": ["gradle"],
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "breaking"]
    },
    {
      "matchPackageNames": ["androidx.compose.compiler:compiler"],
      "groupName": "Compose Compiler"
    },
    {
      "matchPackageNames": ["org.jetbrains.kotlin.android", "org.jetbrains.kotlin.plugin.*"],
      "groupName": "Kotlin"
    },
    {
      "matchPackagePatterns": ["^androidx"],
      "groupName": "AndroidX"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "dependencies"]
  }
}
